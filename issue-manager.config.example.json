{
  "$schema": "./issue-manager.config.schema.json",

  "project": {
    "name": "my-project",
    "owner": "github-username",
    "projectNumber": 1,
    "projectId": "PVT_xxx"
  },

  "labels": {
    "types": [
      { "name": "feature", "prefix": "feat:" },
      { "name": "bug", "prefix": "fix:" },
      { "name": "infra", "prefix": "infra:" },
      { "name": "task", "prefix": "chore:" },
      { "name": "design", "prefix": "design:" },
      { "name": "idea", "prefix": "idea:" },
      { "name": "research", "prefix": "research:" }
    ],
    "scopes": ["frontend", "backend", "both"],
    "domains": [
      { "name": "auth", "description": "Authentication and authorization" },
      { "name": "ui", "description": "UI components and design system" },
      { "name": "data", "description": "Data management and analytics" },
      { "name": "infra", "description": "Infrastructure and DevOps" }
    ]
  },

  "projectFields": {
    "phase": {
      "fieldId": "PVTSSF_xxx",
      "options": {
        "Phase 1": "option-id-1",
        "Phase 2": "option-id-2",
        "Backlog": "option-id-3"
      }
    },
    "priority": {
      "fieldId": "PVTSSF_yyy",
      "options": {
        "P0 Critical": "option-id-a",
        "P1 Important": "option-id-b",
        "P2 Nice-to-have": "option-id-c"
      }
    },
    "track": {
      "fieldId": "PVTSSF_zzz",
      "options": {}
    }
  },

  "template": {
    "sections": [
      {
        "name": "background",
        "title": "Background",
        "required": true,
        "description": "Problem statement, affected users, service impact"
      },
      {
        "name": "brandCheck",
        "title": "Brand/DNA Check",
        "required": false,
        "checklist": [
          "Does this align with our core values?",
          "Could this be misinterpreted legally?",
          "Is this personalized to the user?"
        ]
      },
      {
        "name": "userScenario",
        "title": "User Scenario",
        "required": true,
        "description": "Step-by-step UX flow with ASCII UI or numbered steps"
      },
      {
        "name": "features",
        "title": "Features",
        "required": true,
        "description": "Feature checklist with priority markers"
      },
      {
        "name": "technicalDesign",
        "title": "Technical Design",
        "required": false,
        "description": "Components, APIs, DB schema, dependencies"
      },
      {
        "name": "designGuidelines",
        "title": "Design Guidelines",
        "required": false,
        "description": "Tone, density, accessibility notes"
      },
      {
        "name": "relatedIssues",
        "title": "Related Issues",
        "required": true,
        "description": "Related issue numbers and relationships"
      }
    ],
    "qualityChecklist": [
      "Is the 'who and why' clear in the background?",
      "Is the UX flow concrete (ASCII UI or steps)?",
      "Are there no prohibited terms?",
      "Is the writing tone appropriate for the audience?",
      "Are dependencies specified?",
      "No duplicates with existing issues?",
      "All 3 label axes assigned (type + scope + domain)?"
    ]
  },

  "references": [
    "CLAUDE.md",
    "docs/glossary.md"
  ],

  "language": "en",

  "projectContext": {
    "_comment": "Auto-generated by /issue-setup. Baseline always present, docs layer on top. Re-sync: /issue-setup --learn",
    "description": "",
    "guidelines": [
      {
        "category": "Issue Quality",
        "source": "baseline",
        "rules": [
          "Clearly state the problem and who is affected",
          "Include concrete user scenario or steps to reproduce",
          "Define acceptance criteria (how do we know it's done?)",
          "Check for duplicate issues before creating"
        ]
      }
    ],
    "terminology": [],
    "users": [
      {
        "name": "User",
        "context": "General user of the product"
      }
    ]
  },

  "scoring": {
    "maxScore": 14,
    "thresholds": {
      "good": 10,
      "needsWork": 7
    }
  }
}
